{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "ApiVolunteerProperties#",
  "definitions": {
    "ApiVolunteerProperties": {
      "$id": "ApiVolunteerProperties",
      "type": "object",
      "properties": {
        "id": {
          "type": ["string", "number"]
        },
        "person": {
          "$ref": "ApiPersonGet#"
        },
        "status": {
          "$ref": "VolunteerStateType#"
        },
        "statusEngagement": {
          "$ref": "VolunteerStateEngagementType#"
        },
        "statusCommunication": {
          "$ref": "VolunteerStateCommunicationType#"
        },
        "statusAppreciation": {
          "$ref": "VolunteerStateAppreciationType#"
        },
        "statusType": {
          "$ref": "VolunteerStateTypeType#"
        },
        "statusMatch": {
          "$ref": "VolunteerStateMatchType#"
        },
        "statusCgcProcess": {
          "$ref": "VolunteerStateCGCType#"
        },
        "languages": {
          "type": "array",
          "items": {
            "$ref": "Language#"
          }
        },
        "availability": {
          "type": "array",
          "items": {
            "$ref": "Timeslot#"
          }
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "OptionItem#"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "OptionItem#"
          }
        },
        "locations": {
          "type": "array",
          "items": {
            "$ref": "OptionItem#"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "goodConductCertificate": {
          "$ref": "DocumentStatusType#"
        },
        "measlesVaccination": {
          "$ref": "DocumentStatusType#"
        },
        "preferredCommunicationType": {
          "type": "array",
          "items": {
            "$ref": "VolunteerCommunicationType#"
          }
        },
        "infoAbout": {
          "type": "string"
        },
        "infoExperience": {
          "type": "string"
        },
        "timelineLogs": {
          "type": "array",
          "items": {
            "$ref": "TimedText#"
          }
        },
        "comments": {
          "type": "array",
          "items": {
            "$ref": "TimedText#"
          }
        },
        "opportunitiesApplied": {
          "type": "array",
          "items": {
            "$ref": "Option#"
          }
        },
        "opportunitiesMatched": {
          "type": "array",
          "items": {
            "$ref": "Option#"
          }
        }
      }
    }
  }
}
