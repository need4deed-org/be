{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "volunteer-api-opportunity",
  "type": "object",
  "properties": {
    "id": {
      "type": "number"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "$ref": "OptionById#"
    },
    "type": {
      "$ref": "VolunteerStateTypeType#"
    },
    "status": {
      "$ref": "OpportunityStatusType#"
    },
    "languages": {
      "type": "array",
      "items": {
        "$ref": "Language#"
      }
    },
    "activities": {
      "$ref": "OptionById#"
    },
    "location": {
      "$ref": "OptionById#"
    },
    "availability": {
      "type": "array",
      "items": {
        "$ref": "ApiAvailability#"
      }
    }
  },
  "required": [
    "id",
    "title",
    "category",
    "type",
    "status",
    "languages",
    "activities",
    "location",
    "availability"
  ],
  "additionalProperties": false
}
