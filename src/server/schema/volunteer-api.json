{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "ApiVolunteerGetList#",
  "definitions": {
    "ApiVolunteerGetList": {
      "$id": "ApiVolunteerGetList",
      "type": "object",
      "properties": {
        "id": {
          "type": ["number", "string"]
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "avatarUrl": {
          "type": ["string", "null"]
        },
        "statusEngagement": {
          "$ref": "VolunteerStateEngagementType#"
        },
        "statusType": {
          "$ref": "VolunteerStateTypeType#"
        },
        "statusMatch": {
          "oneOf": [{ "$ref": "VolunteerStateMatchType#" }, { "type": "null" }]
        },
        "statusCommunication": {
          "oneOf": [
            { "$ref": "VolunteerStateCommunicationType#" },
            { "type": "null" }
          ]
        },
        "languages": {
          "type": "array",
          "items": {
            "$ref": "ApiLanguage#"
          }
        },
        "availability": {
          "type": "array",
          "items": {
            "$ref": "ApiAvailability#"
          }
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "OptionItem#"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "OptionItem#"
          }
        },
        "locations": {
          "type": "array",
          "items": {
            "$ref": "OptionItem#"
          }
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "avatarUrl",
        "statusEngagement",
        "statusType",
        "languages",
        "availability",
        "activities",
        "skills",
        "locations"
      ],
      "additionalProperties": false
    }
  }
}
