{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ApiVolunteerGetList",
  "definitions": {
    "ApiVolunteerGetList": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "nativeLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fluentLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "intermediateLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "availability": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "Monday",
                      "Tuesday",
                      "Wednesday",
                      "Thursday",
                      "Friday",
                      "Saturday",
                      "Sunday"
                    ]
                  },
                  { "type": "string", "enum": ["occasionally"] }
                ]
              },
              "daytime": {
                "anyOf": [
                  {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "0:00",
                        "1:00",
                        "2:00",
                        "3:00",
                        "4:00",
                        "5:00",
                        "6:00",
                        "7:00",
                        "8:00",
                        "9:00",
                        "10:00",
                        "11:00",
                        "12:00",
                        "13:00",
                        "14:00",
                        "15:00",
                        "16:00",
                        "17:00",
                        "18:00",
                        "19:00",
                        "20:00",
                        "21:00",
                        "22:00",
                        "23:00",
                        "24:00"
                      ]
                    },
                    "minItems": 2,
                    "maxItems": 2
                  },
                  {
                    "type": "string",
                    "enum": ["weekends", "weekdays"]
                  }
                ]
              }
            },
            "required": ["day", "daytime"],
            "additionalProperties": false
          }
        },
        "activities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "nativeLanguages",
        "fluentLanguages",
        "intermediateLanguages",
        "availability",
        "activities",
        "locations",
        "skills"
      ],
      "additionalProperties": false
    }
  }
}
