{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "OccasionalType": {
      "$id": "OccasionalType",
      "type": "string",
      "enum": ["weekends", "weekdays"]
    },
    "Address": {
      "$id": "Address",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "postcode": {
          "$ref": "Postcode#"
        }
      },
      "additionalProperties": false
    },
    "FilterParamsType": {
      "$id": "FilterParamsType",
      "type": "string",
      "enum": [
        "accompanying",
        "district",
        "engagement",
        "availability",
        "languages"
      ]
    },
    "Postcode": {
      "$id": "Postcode",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "DocumentStatusType": {
      "$id": "DocumentStatusType",
      "type": "string",
      "enum": [
        "undefined",
        "yes",
        "no",
        "asked_to_apply",
        "applied_self",
        "applied_n4d"
      ]
    },
    "TimedText": {
      "$id": "TimedText",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "content": {
          "type": "string"
        },
        "authorName": {
          "type": "string"
        }
      },
      "required": ["id", "timestamp", "content", "authorName"],
      "additionalProperties": false
    },
    "TimedTextType": {
      "$id": "TimedTextType",
      "type": "string",
      "enum": ["create", "update", "remove"]
    },
    "Option": {
      "$id": "Option",
      "type": "object",
      "properties": {
        "id": {
          "$ref": "OptionId#"
        },
        "title": {
          "$ref": "OptionTitle#"
        }
      },
      "required": ["id", "title"],
      "additionalProperties": false
    },
    "OptionId": {
      "$id": "OptionId",
      "type": ["string", "number"]
    },
    "OptionTitle": {
      "$id": "OptionTitle",
      "type": "object",
      "properties": {
        "en": {
          "type": "string"
        },
        "de": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ApiComment": {
      "$id": "ApiComment",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "content": { "type": "string" },
        "entityId": { "type": "number" },
        "entityType": { "type": "string" },
        "authorName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ApiPersonGet": {
      "$id": "ApiPersonGet",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "middleName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "$ref": "Address#" },
        "avatarUrl": { "type": "string" }
      }
    },
    "VolunteerStateType": {
      "$id": "VolunteerStateType",
      "type": "string",
      "enum": [
        "New",
        "Opportunity sent",
        "Matched",
        "Active regular",
        "Active accompany",
        "Active fest",
        "To rematch",
        "Temp inactive",
        "Inactive"
      ]
    },
    "VolunteerStateEngagementType": {
      "$id": "VolunteerStateEngagementType",
      "type": "string",
      "enum": [
        "new",
        "active",
        "available",
        "temp-unavailable",
        "inactive",
        "unresponsive"
      ]
    },
    "VolunteerStateCommunicationType": {
      "$id": "VolunteerStateCommunicationType",
      "type": "string",
      "enum": [
        "called",
        "email-sent",
        "briefed",
        "tried-call",
        "not-responding"
      ]
    },
    "VolunteerStateAppreciationType": {
      "$id": "VolunteerStateAppreciationType",
      "type": "string",
      "enum": ["t-shirt", "benefit-card", "tote-bag"]
    },
    "VolunteerStateTypeType": {
      "$id": "VolunteerStateTypeType",
      "type": "string",
      "enum": ["accompanying", "general", "event", "festival", "weekend-only"]
    },
    "VolunteerStateMatchType": {
      "$id": "VolunteerStateMatchType",
      "type": "string",
      "enum": ["matched", "needs-rematching"]
    },
    "VolunteerStateCGCType": {
      "$id": "VolunteerStateCGCType",
      "type": "string",
      "enum": ["accompanying", "other"]
    },
    "OptionItem": {
      "$id": "OptionItem",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "id": { "type": "number" }
      },
      "required": ["title", "id"],
      "additionalProperties": false
    },
    "ApiLanguage": {
      "$id": "ApiLanguage",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "proficiency": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "fluent", "native"]
        },
        "additionalProperties": false
      },
      "required": ["title", "proficiency"]
    }
  }
}
