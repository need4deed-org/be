{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sdk-types",
  "definitions": {
    "OccasionalType": {
      "$id": "OccasionalType",
      "type": "string",
      "enum": ["weekends", "weekdays"]
    },
    "Address": {
      "$id": "Address",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "postcode": {
          "$ref": "Postcode#"
        }
      },
      "additionalProperties": false
    },
    "FilterParamsType": {
      "$id": "FilterParamsType",
      "type": "string",
      "enum": [
        "accompanying",
        "district",
        "engagement",
        "availability",
        "languages"
      ]
    },
    "Postcode": {
      "$id": "Postcode",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "DocumentStatusType": {
      "$id": "DocumentStatusType",
      "type": "string",
      "enum": [
        "undefined",
        "yes",
        "no",
        "asked_to_apply",
        "applied_self",
        "applied_n4d"
      ]
    },
    "VolunteerCommunicationType": {
      "$id": "VolunteerCommunicationType",
      "type": "string",
      "enum": ["email", "mobilePhone", "whatsapp", "telegram"]
    },
    "TimedText": {
      "$id": "TimedText",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "content": {
          "type": "string"
        },
        "authorName": {
          "type": "string"
        }
      },
      "required": ["id", "timestamp", "content", "authorName"],
      "additionalProperties": false
    },
    "TimedTextType": {
      "$id": "TimedTextType",
      "type": "string",
      "enum": ["create", "update", "remove"]
    },
    "Option": {
      "$id": "Option",
      "type": "object",
      "properties": {
        "id": {
          "$ref": "OptionId#"
        },
        "title": {
          "$ref": "OptionTitle#"
        }
      },
      "required": ["id", "title"],
      "additionalProperties": false
    },
    "OptionId": {
      "$id": "OptionId",
      "type": ["string", "number"]
    },
    "OptionTitle": {
      "$id": "OptionTitle",
      "type": "object",
      "properties": {
        "en": {
          "type": "string"
        },
        "de": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ApiComment": {
      "$id": "ApiComment",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "content": { "type": "string" },
        "entityId": { "type": "number" },
        "entityType": { "type": "string" },
        "authorName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ApiPersonGet": {
      "$id": "ApiPersonGet",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "middleName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "$ref": "Address#" },
        "avatarUrl": { "type": "string" }
      }
    },
    "VolunteerStateType": {
      "$id": "VolunteerStateType",
      "type": "string",
      "enum": [
        "New",
        "Opportunity sent",
        "Matched",
        "Active regular",
        "Active accompany",
        "Active fest",
        "To rematch",
        "Temp inactive",
        "Inactive"
      ]
    },
    "VolunteerStateEngagementType": {
      "$id": "VolunteerStateEngagementType",
      "type": "string",
      "enum": [
        "new",
        "active",
        "available",
        "temp-unavailable",
        "inactive",
        "unresponsive"
      ]
    },
    "VolunteerStateCommunicationType": {
      "$id": "VolunteerStateCommunicationType",
      "type": "string",
      "enum": [
        "called",
        "email-sent",
        "briefed",
        "tried-call",
        "not-responding"
      ]
    },
    "VolunteerStateAppreciationType": {
      "$id": "VolunteerStateAppreciationType",
      "type": "string",
      "enum": ["t-shirt", "benefit-card", "tote-bag"]
    },
    "VolunteerStateTypeType": {
      "$id": "VolunteerStateTypeType",
      "type": "string",
      "enum": ["accompanying", "regular", "events", "regular-accompanying"]
    },
    "VolunteerStateMatchType": {
      "$id": "VolunteerStateMatchType",
      "type": "string",
      "enum": ["matched", "needs-rematching"]
    },
    "VolunteerStateCGCType": {
      "$id": "VolunteerStateCGCType",
      "type": "string",
      "enum": ["accompanying", "other"]
    },
    "OptionItem": {
      "$id": "OptionItem",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "id": { "type": "number" }
      },
      "required": ["title", "id"],
      "additionalProperties": false
    },
    "ApiLanguage": {
      "$id": "ApiLanguage",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "proficiency": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "fluent", "native"]
        },
        "additionalProperties": false
      },
      "required": ["title", "proficiency"]
    },
    "ApiAvailability": {
      "$id": "ApiAvailability",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "day": {
          "type": "string",
          "enum": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday",
            "occasionally"
          ]
        },
        "daytime": {
          "type": "string",
          "enum": ["08-11", "11-14", "14-17", "17-20", "weekdays", "weekends"]
        }
      }
    },
    "ApiUserMe": {
      "$id": "ApiUserMe",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "email": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin", "coordinator", "agent", "volunteer"]
        },
        "firstName": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string"
        },
        "isoCode": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "additionalProperties": false
      },
      "required": ["id", "email", "role"]
    },
    "DocumentType": {
      "$id": "DocumentType",
      "type": "string",
      "enum": [
        "passport-copy",
        "CGC-application",
        "good-conduct-cert",
        "measles-vacc-cert"
      ]
    },
    "ApiDocumentGet": {
      "$id": "ApiDocumentGet",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "type": { "$ref": "DocumentType#" },
        "originalName": { "type": "string" },
        "url": { "type": "string" },
        "mimeType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "originalName", "url", "mimeType"]
    },
    "ApiDocumentPost": {
      "$id": "ApiDocumentPost",
      "type": "object",
      "properties": {
        "type": { "$ref": "DocumentType#" },
        "originalName": { "type": "string" },
        "mimeType": { "type": "string" }
      },
      "required": ["type", "originalName", "mimeType"]
    },
    "ContactType": {
      "$id": "ContactType",
      "type": "string",
      "enum": ["called", "tried-to-call", "texted-or-emailed", "other"]
    },
    "ContactMethodType": {
      "$id": "ContactMethodType",
      "type": "string",
      "enum": [
        "email",
        "phone-number",
        "telegram",
        "whatsapp",
        "signal",
        "sms",
        "voicenote"
      ]
    },
    "CommunicationType": {
      "$id": "CommunicationType",
      "type": "string",
      "enum": [
        "briefed",
        "first-inquiry-sent",
        "opportunity-list-sent",
        "status-update",
        "post-match-followup"
      ]
    },
    "ApiCommunicationGet": {
      "$id": "ApiCommunicationGet",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "contactType": { "$ref": "ContactType#" },
        "contactMethod": { "$ref": "ContactMethodType#" },
        "communicationType": { "$ref": "CommunicationType#" },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "number" },
        "volunteerId": { "type": "number" }
      },
      "required": [
        "id",
        "contactType",
        "contactMethod",
        "date",
        "userId",
        "volunteerId"
      ]
    },
    "ApiCommunication": {
      "$id": "ApiCommunication",
      "type": "object",
      "properties": {
        "contactType": { "$ref": "ContactType#" },
        "contactMethod": { "$ref": "ContactMethodType#" },
        "communicationType": { "$ref": "CommunicationType#" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "ApiCommunicationPost": {
      "$id": "ApiCommunicationPost",
      "allOf": [{ "$ref": "ApiCommunication#" }],
      "required": ["contactType", "contactMethod", "date"]
    },
    "ApiCommunicationPatch": {
      "$id": "ApiCommunicationPatch",
      "$ref": "ApiCommunication#"
    },
    "ApiAppreciationGet": {
      "$id": "ApiAppreciationGet",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "title": { "$ref": "VolunteerStateAppreciationType#" },
        "dateDue": { "type": "string", "format": "date-time" },
        "dateDelivery": { "type": "string", "format": "date-time" },
        "userId": { "type": "number" },
        "opportunityId": { "type": "number" },
        "volunteerId": { "type": "number" }
      },
      "required": [
        "id",
        "title",
        "dateDue",
        "userId",
        "opportunityId",
        "volunteerId"
      ]
    },
    "ApiAppreciation": {
      "$id": "ApiAppreciation",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "title": { "$ref": "VolunteerStateAppreciationType#" },
        "dateDue": { "type": "string", "format": "date-time" },
        "dateDelivery": { "type": "string", "format": "date-time" },
        "userId": { "type": "number" },
        "opportunityId": { "type": "number" },
        "volunteerId": { "type": "number" }
      }
    },
    "AppreciationPost": {
      "$id": "ApiAppreciationPost",
      "allOff": [{ "$ref": "ApiAppreciation#" }],
      "required": ["title", "volunteerId", "dateDue"]
    },
    "AppreciationPatch": {
      "$id": "ApiAppreciationPatch",
      "$ref": "ApiAppreciation#"
    }
  }
}
