{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sdk-types",
  "definitions": {
    "OccasionalType": {
      "$id": "OccasionalType",
      "type": "string",
      "enum": ["weekends", "weekdays"]
    },
    "Address": {
      "$id": "Address",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "postcode": {
          "$ref": "Postcode#"
        }
      },
      "additionalProperties": false
    },
    "FilterParamsType": {
      "$id": "FilterParamsType",
      "type": "string",
      "enum": [
        "accompanying",
        "district",
        "engagement",
        "availability",
        "languages"
      ]
    },
    "Postcode": {
      "$id": "Postcode",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "DocumentStatusType": {
      "$id": "DocumentStatusType",
      "type": "string",
      "enum": [
        "undefined",
        "yes",
        "no",
        "asked_to_apply",
        "applied_self",
        "applied_n4d"
      ]
    },
    "PreferredCommunicationType": {
      "$id": "PreferredCommunicationType",
      "type": "string",
      "enum": ["email", "mobilePhone", "whatsapp", "telegram"]
    },
    "VolunteerCommunicationType": {
      "$id": "VolunteerCommunicationType",
      "$ref": "PreferredCommunicationType#"
    },
    "TimedText": {
      "$id": "TimedText",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "content": {
          "type": "string"
        },
        "authorName": {
          "type": "string"
        }
      },
      "required": ["id", "timestamp", "content", "authorName"],
      "additionalProperties": false
    },
    "TimedTextType": {
      "$id": "TimedTextType",
      "type": "string",
      "enum": ["create", "update", "remove"]
    },
    "Option": {
      "$id": "Option",
      "type": "object",
      "properties": {
        "id": {
          "$ref": "OptionId#"
        },
        "title": {
          "$ref": "OptionTitle#"
        }
      },
      "required": ["id", "title"],
      "additionalProperties": false
    },
    "OptionId": {
      "$id": "OptionId",
      "type": ["string", "number"]
    },
    "OptionById": {
      "$id": "OptionById",
      "type": "object",
      "properties": {
        "id": {
          "$ref": "OptionId#"
        },
        "title": {
          "$ref": "OptionTitle#"
        }
      },
      "additionalProperties": false
    },
    "OptionTitle": {
      "$id": "OptionTitle",
      "type": "object",
      "properties": {
        "en": {
          "type": "string"
        },
        "de": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ApiComment": {
      "$id": "ApiComment",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "content": { "type": "string" },
        "entityId": { "type": "number" },
        "entityType": { "type": "string" },
        "authorName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ApiPerson": {
      "$id": "ApiPerson",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "avatarUrl": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "middleName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "$ref": "Address#" },
        "preferredComm": { "$ref": "PreferredCommunicationType#" }
      }
    },
    "ApiPersonGet": {
      "$id": "ApiPersonGet",
      "$ref": "ApiPerson#",
      "required": ["id", "firstName", "email"]
    },
    "ApiPersonPatch": {
      "$id": "ApiPersonPatch",
      "$ref": "ApiPerson#"
    },
    "VolunteerStateType": {
      "$id": "VolunteerStateType",
      "type": "string",
      "enum": [
        "New",
        "Opportunity sent",
        "Matched",
        "Active regular",
        "Active accompany",
        "Active fest",
        "To rematch",
        "Temp inactive",
        "Inactive"
      ]
    },
    "VolunteerStateEngagementType": {
      "$id": "VolunteerStateEngagementType",
      "type": "string",
      "enum": [
        "new",
        "active",
        "available",
        "temp-unavailable",
        "inactive",
        "unresponsive"
      ]
    },
    "VolunteerStateCommunicationType": {
      "$id": "VolunteerStateCommunicationType",
      "type": "string",
      "enum": [
        "called",
        "email-sent",
        "briefed",
        "tried-call",
        "not-responding"
      ]
    },
    "VolunteerStateAppreciationType": {
      "$id": "VolunteerStateAppreciationType",
      "type": "string",
      "enum": ["t-shirt", "benefit-card", "tote-bag"]
    },
    "VolunteerStateTypeType": {
      "$id": "VolunteerStateTypeType",
      "type": "string",
      "enum": ["accompanying", "regular", "events", "regular-accompanying"]
    },
    "VolunteerStateMatchType": {
      "$id": "VolunteerStateMatchType",
      "type": "string",
      "enum": ["matched", "needs-rematching"]
    },
    "VolunteerStateCGCType": {
      "$id": "VolunteerStateCGCType",
      "type": "string",
      "enum": ["accompanying", "other"]
    },
    "OpportunityVolunteerStatusType": {
      "$id": "OpportunityVolunteerStatusType",
      "type": "string",
      "enum": ["pending", "matched", "active", "past"]
    },
    "OptionItem": {
      "$id": "OptionItem",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "id": { "type": "number" }
      },
      "required": ["title", "id"],
      "additionalProperties": false
    },
    "ApiLanguage": {
      "$id": "ApiLanguage",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "proficiency": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "fluent", "native"]
        },
        "additionalProperties": false
      },
      "required": ["title", "proficiency"]
    },
    "ApiAvailability": {
      "$id": "ApiAvailability",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "day": {
          "type": "string",
          "enum": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday",
            "occasionally"
          ]
        },
        "daytime": {
          "type": "string",
          "enum": ["08-11", "11-14", "14-17", "17-20", "weekdays", "weekends"]
        }
      }
    },
    "ApiUserMe": {
      "$id": "ApiUserMe",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "email": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin", "coordinator", "agent", "volunteer"]
        },
        "firstName": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string"
        },
        "isoCode": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "additionalProperties": false
      },
      "required": ["id", "email", "role"]
    },
    "DocumentType": {
      "$id": "DocumentType",
      "type": "string",
      "enum": [
        "passport-copy",
        "CGC-application",
        "good-conduct-cert",
        "measles-vacc-cert"
      ]
    },
    "ApiDocumentGet": {
      "$id": "ApiDocumentGet",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "type": { "$ref": "DocumentType#" },
        "originalName": { "type": "string" },
        "url": { "type": "string" },
        "mimeType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "originalName", "url", "mimeType"]
    },
    "ApiDocumentPost": {
      "$id": "ApiDocumentPost",
      "type": "object",
      "properties": {
        "type": { "$ref": "DocumentType#" },
        "originalName": { "type": "string" },
        "mimeType": { "type": "string" }
      },
      "required": ["type", "originalName", "mimeType"]
    },
    "ContactType": {
      "$id": "ContactType",
      "type": "string",
      "enum": ["called", "tried-to-call", "texted-or-emailed", "other"]
    },
    "ContactMethodType": {
      "$id": "ContactMethodType",
      "type": "string",
      "enum": [
        "email",
        "phone-number",
        "telegram",
        "whatsapp",
        "signal",
        "sms",
        "voicenote"
      ]
    },
    "CommunicationType": {
      "$id": "CommunicationType",
      "type": "string",
      "enum": [
        "briefed",
        "first-inquiry-sent",
        "opportunity-list-sent",
        "status-update",
        "post-match-followup"
      ]
    },
    "ApiCommunication": {
      "$id": "ApiCommunication",
      "type": "object",
      "properties": {
        "contactType": { "$ref": "ContactType#" },
        "contactMethod": { "$ref": "ContactMethodType#" },
        "communicationType": { "$ref": "CommunicationType#" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "ApiCommunicationGet": {
      "$id": "ApiCommunicationGet",
      "type": "object",
      "allOf": [
        { "$ref": "ApiCommunication#" },
        {
          "type": "object",
          "properties": {
            "id": { "type": "number" },
            "userId": { "type": "number" },
            "volunteerId": { "type": "number" }
          }
        }
      ],
      "required": [
        "id",
        "contactType",
        "contactMethod",
        "date",
        "userId",
        "volunteerId"
      ]
    },
    "ApiCommunicationPost": {
      "$id": "ApiCommunicationPost",
      "allOf": [{ "$ref": "ApiCommunication#" }],
      "required": ["contactType", "contactMethod", "date"]
    },
    "ApiCommunicationPatch": {
      "$id": "ApiCommunicationPatch",
      "$ref": "ApiCommunication#"
    },
    "ApiAppreciation": {
      "$id": "ApiAppreciation",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "title": { "$ref": "VolunteerStateAppreciationType#" },
        "dateDue": { "type": ["string", "null"], "format": "date-time" },
        "dateDelivery": { "type": ["string", "null"], "format": "date-time" },
        "userId": { "type": "number" },
        "opportunityId": { "type": "number" },
        "volunteerId": { "type": "number" }
      }
    },
    "ApiAppreciationGet": {
      "$id": "ApiAppreciationGet",
      "$ref": "ApiAppreciation#",
      "required": [
        "id",
        "title",
        "dateDue",
        "userId",
        "opportunityId",
        "volunteerId"
      ]
    },
    "ApiAppreciationPost": {
      "$id": "ApiAppreciationPost",
      "$ref": "ApiAppreciation#",
      "required": ["title", "dateDue"]
    },
    "ApiAppreciationPatch": {
      "$id": "ApiAppreciationPatch",
      "$ref": "ApiAppreciation#"
    },
    "ApiVolunteerOpportunity": {
      "$id": "ApiVolunteerOpportunity",
      "type": "object",
      "properties": {
        "opportunityId": { "type": "number" },
        "volunteerId": { "type": "number" },
        "title": { "type": "string" },
        "status": { "$ref": "OpportunityVolunteerStatusType#" }
      }
    },
    "ApiVolunteerOpportunityGet": {
      "$id": "ApiVolunteerOpportunityGet",
      "type": "object",
      "allOf": [
        { "$ref": "ApiVolunteerOpportunity#" },
        {
          "type": "object",
          "properties": {
            "id": { "type": "number" },
            "updatedAt": { "type": "string", "format": "date-time" }
          }
        }
      ],
      "required": [
        "id",
        "opportunityId",
        "volunteerId",
        "title",
        "status",
        "updatedAt"
      ]
    },
    "ApiVolunteerOpportunityPatch": {
      "$id": "ApiVolunteerOpportunityPatch",
      "type": "object",
      "properties": {
        "status": { "$ref": "OpportunityVolunteerStatusType#" }
      },
      "required": ["status"]
    },
    "OpportunityType": {
      "$id": "OpportunityType",
      "type": "string",
      "enum": ["accompanying", "regular", "events"]
    },
    "OpportunityStatusType": {
      "$id": "OpportunityStatusType",
      "type": "string",
      "enum": ["new", "searching", "active", "past"]
    },
    "ApiOpportunityGetList": {
      "$id": "ApiOpportunityGetList",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "volunteerType": { "$ref": "OpportunityType#" },
        "statusOpportunity": { "$ref": "OpportunityStatusType#" },
        "title": { "type": "string" },
        "category": {
          "type": "object",
          "properties": { "id": { "type": "number" } }
        }
      },
      "required": [
        "id",
        "volunteerType",
        "statusOpportunity",
        "title",
        "category"
      ]
    },
    "AgentType": {
      "$id": "AgentType",
      "type": "string",
      "enum": ["rac", "ngo"]
    },
    "ApiAgent": {
      "$id": "ApiAgent",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "type": { "$ref": "AgentType#" },
        "address": { "$ref": "Address#" },
        "district": { "$ref": "Option#" },
        "activeVolunteers": { "type": "integer" }
      }
    },
    "ApiAgentGetList": {
      "$id": "ApiAgentGetList",
      "$ref": "ApiAgent#",
      "required": ["id", "title", "type"]
    }
  }
}
