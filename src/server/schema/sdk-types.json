{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "OccasionalType": {
      "type": "string",
      "enum": ["weekends", "weekdays"]
    },
    "Address": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "postcode": {
          "$ref": "#/definitions/Postcode"
        }
      },
      "additionalProperties": false
    },
    "Postcode": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "DocumentStatusType": {
      "type": "string",
      "enum": [
        "undefined",
        "yes",
        "no",
        "asked_to_apply",
        "applied_self",
        "applied_n4d"
      ]
    },
    "TimedText": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "type": {
          "$ref": "#/definitions/TimedTextType"
        },
        "text": {
          "type": "string"
        }
      },
      "required": ["date", "type", "text"],
      "additionalProperties": false
    },
    "TimedTextType": {
      "type": "string",
      "enum": ["create", "update", "remove"]
    },
    "Option": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/definitions/OptionId"
        },
        "title": {
          "$ref": "#/definitions/OptionTitle"
        }
      },
      "required": ["id", "title"],
      "additionalProperties": false
    },
    "OptionId": {
      "type": ["string", "number"]
    },
    "OptionTitle": {
      "type": "object",
      "properties": {
        "en": {
          "type": "string"
        },
        "de": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ApiPersonGet": {
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "middleName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "$ref": "#/definitions/Address" },
        "avatarUrl": { "type": "string" }
      }
    },
    "VolunteerStateType": {
      "type": "string",
      "enum": [
        "New",
        "Opportunity sent",
        "Matched",
        "Active regular",
        "Active accompany",
        "Active fest",
        "To rematch",
        "Temp inactive",
        "Inactive"
      ]
    },
    "VolunteerStateEngagementType": {
      "type": "string",
      "enum": [
        "new",
        "active",
        "available",
        "temp-unavailable",
        "inactive",
        "unresponsive"
      ]
    },
    "VolunteerStateCommunicationType": {
      "type": "string",
      "enum": [
        "called",
        "email-sent",
        "briefed",
        "tried-call",
        "not-responding"
      ]
    },
    "VolunteerStateAppreciationType": {
      "type": "string",
      "enum": ["t-shirt", "benefit-card", "tote-bag"]
    },
    "VolunteerStateTypeType": {
      "type": "string",
      "enum": ["accompanying", "general", "event", "festival", "weekend-only"]
    },
    "VolunteerStateMatchType": {
      "type": "string",
      "enum": ["matched", "needs-rematching"]
    },
    "VolunteerStateCGCType": {
      "type": "string",
      "enum": ["accompanying", "other"]
    },
    "OptionItem": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "id": { "type": "number" }
      },
      "required": ["title", "id"],
      "additionalProperties": false
    }
  }
}
