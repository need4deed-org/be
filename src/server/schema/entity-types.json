{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Timeslot": {
      "$id": "Timeslot",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "day": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday",
                "Sunday"
              ]
            },
            { "type": "string", "enum": ["occasionally"] }
          ]
        },
        "daytime": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "0:00",
                  "1:00",
                  "2:00",
                  "3:00",
                  "4:00",
                  "5:00",
                  "6:00",
                  "7:00",
                  "8:00",
                  "9:00",
                  "10:00",
                  "11:00",
                  "12:00",
                  "13:00",
                  "14:00",
                  "15:00",
                  "16:00",
                  "17:00",
                  "18:00",
                  "19:00",
                  "20:00",
                  "21:00",
                  "22:00",
                  "23:00",
                  "24:00"
                ]
              },
              "minItems": 2,
              "maxItems": 2
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["weekends", "weekdays"]
              },
              "minItems": 1,
              "maxItems": 1
            }
          ]
        }
      },
      "required": ["day", "daytime"],
      "additionalProperties": false
    },
    "Language": {
      "$id": "Language",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "title": {
          "type": "string"
        },
        "proficiency": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "fluent", "native"]
        },
        "additionalProperties": false
      }
    },
    "Comment": {
      "$id": "Comment",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "text": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "user": {
          "$ref": "User#"
        },
        "entityId": {
          "type": "number"
        },
        "entityType": {
          "type": "string",
          "enum": ["volunteer", "opportunity"]
        }
      },
      "additionalProperties": false
    },
    "User": {
      "$id": "User",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "isActive": {
          "type": "boolean"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "coordinator", "user"]
        },
        "language": {
          "$ref": "Language#"
        },
        "timezone": {
          "type": "string"
        },
        "person": {
          "$ref": "Person#"
        }
      },
      "additionalProperties": false
    },
    "Person": {
      "$id": "Person",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "firstName": {
          "type": "string"
        },
        "middleName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
